# Supabase Configuration
# Copy this file to .env and fill in your Supabase project details
# You can find these values in your Supabase project settings under:
# Settings > API > Project URL and Project API keys

# Required for production deployment
# Format: https://your-project-id.supabase.co
VITE_SUPABASE_URL=your_supabase_project_url

# Required for production deployment
# Use the "anon" public key (safe to expose in client-side code)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
